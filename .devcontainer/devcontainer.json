{
  "name": "mysql-python-docker",
  "dockerComposeFile": ["../docker-compose.yml", "docker-compose.devcontainer.yml"],
  "service": "app",
  "workspaceFolder": "/app",

  "customizations": {
    "zed": {
      "extensions": ["python"]
    }
  },

  "remoteEnv": {
    "PYTHONPATH": "/app/src"
  },

  "postCreateCommand": "pip install -r requirements.txt"
}
